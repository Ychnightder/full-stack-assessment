{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "startD": "ng serve --host 0.0.0.0 --port 4200 --poll 2000",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "npx vitest run",
    "clean": "npx prettier . --write"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.5.2",
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "ci": "^2.3.0",
    "leaflet": "^1.9.4",
    "ngx-chartjs": "^0.0.1",
    "rxjs": "~7.8.0",
    "scss": "^0.2.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@types/axios": "^0.9.36",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.15",
    "axios-mock-adapter": "^2.1.0",
    "c8": "^10.1.3",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.15",
    "zone.js": "^0.16.0"
  }
}
